# Copy this file to .env and fill in your own values.
# NEVER commit your real .env file to git — it is already listed in .gitignore.

# Session secret - use a long random string in production
SESSION_SECRET=change-this-to-a-long-random-string

# Server port
PORT=3000

# ---- SMTP settings for OTP e-mails ----
# Example values for Gmail (requires an "App Password", not your normal password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your-16-char-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Hostel Attendance Register

# Path to the SQLite database file (kept inside the repo per project requirement)
DB_PATH=./database/hostel.db
